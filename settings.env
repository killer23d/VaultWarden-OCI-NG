# Domain Configuration
DOMAIN_NAME=your.domain.com # TODO: Replace with your actual domain (e.g., mydomain.com)
APP_DOMAIN=vault.${DOMAIN_NAME}

# MariaDB
MARIADB_ROOT_PASSWORD=<random-32-char-string> # Generate: openssl rand -base64 32
MARIADB_DATABASE=bitwarden_vault
MARIADB_USER=bitwarden
MARIADB_PASSWORD=<random-32-char-string> # Generate: openssl rand -base64 32
DATABASE_URL=mysql://bitwarden:$MARIADB_PASSWORD@mariadb:3306/bitwarden_vault

# Vaultwarden
ADMIN_TOKEN=<random-32-char-string> # Generate: openssl rand -base64 32, for admin page access
SIGNUPS_ALLOWED=false
INVITES_ALLOWED=true
DOMAIN=https://$APP_DOMAIN
PUSH_ENABLED=true
PUSH_INSTALLATION_ID=<obtain-from-bitwarden> # TODO: Obtain from https://bitwarden.com/host
PUSH_INSTALLATION_KEY=<obtain-from-bitwarden> # TODO: Obtain from https://bitwarden.com/host
PUSH_RELAY_URI=https://push.bitwarden.com

# Redis
REDIS_PASSWORD=<random-32-char-string> # Generate: openssl rand -base64 32
REDIS_URL=redis://:$REDIS_PASSWORD@redis:6379

# SMTP (MailerSend)
SMTP_HOST=smtp.mailersend.net
SMTP_PORT=587
SMTP_USER=<mailersend-api-token> # TODO: Replace with MailerSend API token
SMTP_PASSWORD=<mailersend-api-token> # TODO: Replace with MailerSend API token
SMTP_FROM=no-reply@${DOMAIN_NAME}
BACKUP_EMAIL_RECIPIENT=backup@${DOMAIN_NAME}

# Backup Encryption
BACKUP_PASSPHRASE=<random-32-char-string> # Generate: openssl rand -base64 32

# Caddy
CADDY_DOMAIN=$APP_DOMAIN
ADMIN_EMAIL=admin@${DOMAIN_NAME}

DDCLIENT_LOGIN=token
CF_API_TOKEN=<cloudflare-api-token>
DDCLIENT_DOMAIN=${DOMAIN_NAME}    # The root domain you own
DDCLIENT_HOST=vault            
    # The subdomain for this service

# fail2ban
FAIL2BAN_DEST=backup@${DOMAIN_NAME}

# Timezone
TZ=America/Los_Angeles

# WATCHTOWER
WATCHTOWER_SCHEDULE=0 0 3 * * 0

# User/Group IDs - Get from host by running `id -u` and `id -g`
PUID=1000
PGID=1000
