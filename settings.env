# Application Domain
APP_DOMAIN=vault.your.domain.com # TODO: Replace with your actual domain (e.g., vault.mydomain.com)

# MariaDB
MARIADB_ROOT_PASSWORD=<random-32-char-string> # Generate: openssl rand -base64 32
MARIADB_DATABASE=bitwarden_vault
MARIADB_USER=bitwarden
MARIADB_PASSWORD=<random-32-char-string> # Generate: openssl rand -base64 32
DATABASE_URL=mysql://bitwarden:$MARIADB_PASSWORD@db:3306/bitwarden_vault

# Bitwarden Unified
ADMIN_EMAIL=admin@your.domain.com
DOMAIN=https://$APP_DOMAIN
SIGNUPS_ALLOWED=false
INVITATIONS_ALLOWED=true
WEBSOCKET_ENABLED=true

# Redis
REDIS_PASSWORD=<random-32-char-string> # Generate: openssl rand -base64 32
REDIS_URL=redis://:$REDIS_PASSWORD@redis:6379

# SMTP (MailerSend)
SMTP_HOST=smtp.mailersend.net
SMTP_PORT=587
SMTP_USER=<mailersend-api-token> # TODO: Replace with MailerSend API token
SMTP_PASSWORD=<mailersend-api-token> # TODO: Replace with MailerSend API token
SMTP_FROM=no-reply@your.domain.com
SMTP_TO=backup@mydomain.com

# Backup Encryption
BACKUP_GPG_RECIPIENT=admin@your.domain.com
BACKUP_PASSPHRASE=<random-32-char-string> # Generate: openssl rand -base64 32

# Caddy
CADDY_DOMAIN=$APP_DOMAIN
CADDY_EMAIL=admin@your.domain.com

# ddclient (Cloudflare)
DDCLIENT_LOGIN=token
DDCLIENT_PASSWORD=<cloudflare-api-token> # TODO: Replace with Cloudflare API token (Zone - DNS - Edit, Zone - Zone - Read)
DDCLIENT_ZONE=your.domain.com

# fail2ban
FAIL2BAN_DEST=backup@mydomain.com
