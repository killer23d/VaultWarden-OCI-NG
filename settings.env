# ===========================================
# VAULTWARDEN-OCI CONFIGURATION
# Optimized for Ubuntu 22.04 LTS with 6GB RAM
# ===========================================

# DOMAIN CONFIGURATION
DOMAIN_NAME=your.domain.com
APP_DOMAIN=vault.${DOMAIN_NAME}

# MARIADB CONFIGURATION (Enhanced Performance)
MARIADB_ROOT_PASSWORD=<generate-with-openssl-rand-base64-32>
MARIADB_DATABASE=bitwarden_vault
MARIADB_USER=bitwarden
MARIADB_PASSWORD=<generate-with-openssl-rand-base64-32>
DATABASE_URL=mysql://bitwarden:${MARIADB_PASSWORD}@mariadb:3306/bitwarden_vault

# VAULTWARDEN APPLICATION
ADMIN_TOKEN=<generate-with-openssl-rand-base64-32>
SIGNUPS_ALLOWED=false
INVITES_ALLOWED=true
DOMAIN=https://${APP_DOMAIN}
SHOW_PASSWORD_HINTS=false
DISABLE_2FA_REMEMBER=false

# ENHANCED PERFORMANCE SETTINGS for 6GB RAM
VAULTWARDEN_WORKERS=3
DATABASE_POOL_SIZE=15
REDIS_MAX_CONNECTIONS=25

# PUSH NOTIFICATIONS (Optional)
PUSH_ENABLED=true
PUSH_INSTALLATION_ID=<obtain-from-bitwarden-hosting-portal>
PUSH_INSTALLATION_KEY=<obtain-from-bitwarden-hosting-portal>
PUSH_RELAY_URI=https://push.bitwarden.com

# REDIS CACHE
REDIS_PASSWORD=<generate-with-openssl-rand-base64-32>
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# SMTP CONFIGURATION (MailerSend)
SMTP_HOST=smtp.mailersend.net
SMTP_PORT=587
SMTP_USER=<mailersend-api-token>
SMTP_PASSWORD=<mailersend-api-token>
SMTP_FROM=vault@${DOMAIN_NAME}
BACKUP_EMAIL_RECIPIENT=backup@${DOMAIN_NAME}

# RCLONE BACKUP (Simplified Configuration)
RCLONE_REMOTE_NAME=mycloud                    # Name from your rclone config
RCLONE_REMOTE_PATH=VaultWarden-Backups        # Folder in cloud storage
BACKUP_RETENTION_DAYS=30
BACKUP_PASSPHRASE=<strong-backup-passphrase>
BACKUP_NOTIFICATION_EMAIL=backup@${DOMAIN_NAME}

# CADDY CONFIGURATION
CADDY_DOMAIN=${APP_DOMAIN}
ADMIN_EMAIL=admin@${DOMAIN_NAME}

# DDCLIENT (Dynamic DNS)
DDCLIENT_LOGIN=token
CF_API_TOKEN=<cloudflare-api-token>
DDCLIENT_DOMAIN=${DOMAIN_NAME}
DDCLIENT_HOST=vault

# FAIL2BAN
FAIL2BAN_DEST=security@${DOMAIN_NAME}

# SYSTEM CONFIGURATION
TZ=America/Los_Angeles
PUID=1000
PGID=1000

# WATCHTOWER
WATCHTOWER_SCHEDULE=0 0 3 * * 0

# ===========================================
# SCRIPT CONFIGURATION
# ===========================================

# Container names used by management scripts
# (Ensure these match the 'container_name' in your docker-compose.yml)
VAULTWARDEN_CONTAINER=vaultwarden
CADDY_CONTAINER=bw_caddy
FAIL2BAN_CONTAINER=bw_fail2ban

# Email for script reports (disk space, fail2ban, etc.)
ADMIN_REPORT_EMAIL=admin@your.domain.com
