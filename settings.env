# MariaDB
MARIADB_ROOT_PASSWORD=<random-32-char-string>
MARIADB_DATABASE=bitwarden_vault
MARIADB_USER=bitwarden
MARIADB_PASSWORD=<random-32-char-string>
DATABASE_URL=mysql://bitwarden:<MARIADB_PASSWORD>@db:3306/bitwarden_vault

# Bitwarden Unified
ADMIN_EMAIL=admin@your.domain.com
DOMAIN=https://vault.your.domain.com
SIGNUPS_ALLOWED=false
INVITATIONS_ALLOWED=true
WEBSOCKET_ENABLED=true

# Redis
REDIS_PASSWORD=<random-32-char-string>
REDIS_URL=redis://:<REDIS_PASSWORD>@redis:6379

# SMTP (MailerSend, to be updated)
SMTP_HOST=smtp.mailersend.net
SMTP_PORT=587
SMTP_USER=<mailersend-api-token>
SMTP_PASSWORD=<mailersend-api-token>
SMTP_FROM=no-reply@your.domain.com
SMTP_TO=admin@your.domain.com

# Backup Encryption
BACKUP_GPG_RECIPIENT=admin@your.domain.com
BACKUP_PASSPHRASE=<random-32-char-string>

# Caddy
CADDY_DOMAIN=vault.your.domain.com
CADDY_EMAIL=admin@your.domain.com

# ddclient (Cloudflare)
DDCLIENT_LOGIN=token
DDCLIENT_PASSWORD=<cloudflare-api-token>
DDCLIENT_ZONE=your.domain.com
