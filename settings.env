#############################################
# Bitwarden Unified settings.env (template)
# Fill the values below before starting.
# This file follows Bitwarden Unified environment variable layout.
#############################################

# -------------------------
# General
# -------------------------
globalSettings__baseServiceUri__vault=https://YOUR_DOMAIN
# If you want to disable open registration:
globalSettings__disableUserRegistration=true

# -------------------------
# Database (MySQL/MariaDB)
# -------------------------
# Note: Unified uses the DB described below. This example uses MariaDB in the compose (service name 'db').
# You can either put a connection string or set database provider + connection var names used internally.
globalSettings__databaseProvider=mysql
# MySQL/MariaDB connection string format used by unified internal config (mySql:connectionString)
# Example: server=db;uid=bitwarden;pwd=supersecret;database=bitwarden_vault
globalSettings__mySql__connectionString=server=db;uid=${MARIADB_USER};pwd=${MARIADB_PASSWORD};database=${MARIADB_DATABASE}

# -------------------------
# Redis (optional)
# -------------------------
# If Redis is used by your unified config, provide the URL. Example: redis://redis:6379
globalSettings__redis__connectionString=redis://redis:6379

# -------------------------
# Mail (SMTP) - fill in your SMTP details
# -------------------------
# These are used by fail2ban (alerts) and the backup/emailing (encrypted vault attached).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=bitwarden@example.com
SMTP_TO=your.email@example.com
SMTP_SECURE=starttls   # optional: starttls/tls/none

# -------------------------
# MariaDB root / bitwarden DB creds (used by the mariadb container)
# Move these into .env or set them as env variables in your shell before docker compose up.
# (You may keep these in this file but ensure it is protected; original repo uses .env.template)
# -------------------------
MARIADB_ROOT_PASSWORD=changeme_root_password
MARIADB_DATABASE=bitwarden_vault
MARIADB_USER=bitwarden
MARIADB_PASSWORD=changeme_db_password

# -------------------------
# Backups / Encryption (backup container uses these)
# -------------------------
# GPG public key ID (or empty to use passphrase)
BACKUP_GPG_RECIPIENT=your-gpg-recipient@example.com
BACKUP_PASSPHRASE=super_secret_passphrase  # if you prefer symmetric encryption
BACKUP_KEEP_DAYS=30
BACKUP_LOCAL_DIR=/backups
BACKUP_INCLUDE_ENV=true     # optional: whether to include settings.env in backups (encrypt if true)

# If you want to email backups, the backup container reads SMTP_* above and can send the encrypted file as an attachment.

# -------------------------
# Fail2ban / Misc
# -------------------------
TZ=UTC

# -------------------------
# Example additional Bitwarden feature toggles (unified supports many env keys)
# Add needed globalSettings__* keys here following the Bitwarden env naming scheme.
# For example:
# globalSettings__yubico__clientId=
# globalSettings__yubico__secretKey=
# globalSettings__yubico__validationUrl=
#
# See Bitwarden's Environment Variables docs for the full options.
# -------------------------

#############################################
# END of settings.env
#############################################
