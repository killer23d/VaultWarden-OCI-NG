# fail2ban/jail.local
[DEFAULT]
ignoreip = 127.0.0.1/8 ::1
bantime = 3600
findtime = 600
maxretry = 5
backend = auto
banaction = iptables-multiport

[caddy-404]
enabled = true
filter = caddy-404
action = iptables-multiport[name=caddy-404, port="http,https"]
logpath = /var/log/caddy/access.log
maxretry = 10

[bitwarden-admin]
enabled = true
filter = bitwarden-admin
action = iptables-multiport[name=bitwarden-admin, port="http,https"]
logpath = /var/log/caddy/access.log
maxretry = 3
