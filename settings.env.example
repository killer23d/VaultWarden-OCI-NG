# settings.env.example - Configuration template for Vaultwarden stack
# Copy this file to settings.env and customize the values

# === DOMAIN CONFIGURATION ===
DOMAIN_NAME=example.com
PUID=1000
PGID=1000
TZ=America/Los_Angeles

# === VAULTWARDEN CONFIGURATION ===
ADMIN_TOKEN=your-very-strong-admin-token-here
WEBSOCKET_ENABLED=true
WEB_VAULT_ENABLED=true
SIGNUPS_ALLOWED=false
INVITATIONS_ALLOWED=true
SHOW_PASSWORD_HINT=false

# === DATABASE CONFIGURATION ===
MARIADB_ROOT_PASSWORD=your-very-strong-root-password
MARIADB_DATABASE=vaultwarden
MARIADB_USER=vaultwarden
MARIADB_PASSWORD=your-strong-db-password
DATABASE_URL=mysql://vaultwarden:your-strong-db-password@bw_mariadb:3306/vaultwarden

# === REDIS CONFIGURATION ===
REDIS_PASSWORD=your-strong-redis-password

# === EMAIL CONFIGURATION ===
SMTP_HOST=smtp.mailersend.net
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=MS_your_token_here
SMTP_PASSWORD=MS_your_password_here
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME=Vaultwarden

# === BACKUP CONFIGURATION ===
BACKUP_PASSPHRASE=your-very-strong-backup-passphrase
BACKUP_REMOTE=your-rclone-remote-name
BACKUP_PATH=vaultwarden-backups
BACKUP_RETENTION_DAYS=30
BACKUP_EMAIL=admin@example.com

# === FAIL2BAN CONFIGURATION ===
FAIL2BAN_DEST=admin@example.com

# === DDCLIENT CONFIGURATION ===
DDCLIENT_PROTOCOL=cloudflare
DDCLIENT_LOGIN=your-cloudflare-email
DDCLIENT_PASSWORD=your-cloudflare-token
DDCLIENT_ZONE=example.com
DDCLIENT_HOST=vault.example.com

# === WATCHTOWER CONFIGURATION ===
WATCHTOWER_SCHEDULE=0 0 3 * * 0

# === PUSH NOTIFICATIONS (OPTIONAL) ===
PUSH_INSTALLATION_ID=your-installation-id
PUSH_INSTALLATION_KEY=your-installation-key

# === PERFORMANCE TUNING ===
DATABASE_MAX_CONNECTIONS=15
VAULTWARDEN_WORKERS=3
REDIS_MAX_CONNECTIONS=25

# === MONITORING ===
DISK_ALERT_THRESHOLD=85
ALERT_EMAIL=admin@example.com
