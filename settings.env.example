# ===========================================
# VAULTWARDEN-OCI CONFIGURATION
# Optimized for Ubuntu 22.04 LTS with 6GB RAM
# ===========================================

# === DOMAIN & SECURITY CONFIGURATION ===
DOMAIN_NAME=example.com
APP_DOMAIN=vault.${DOMAIN_NAME}
DOMAIN=https://${APP_DOMAIN}

# System user configuration (1000 for app containers, 999 for system services)
PUID=1000
PGID=1000
TZ=America/Los_Angeles

# === VAULTWARDEN APPLICATION ===
ADMIN_TOKEN=generate-with-openssl-rand-base64-32
SIGNUPS_ALLOWED=false
INVITES_ALLOWED=true
WEBSOCKET_ENABLED=true
WEB_VAULT_ENABLED=true
SHOW_PASSWORD_HINTS=false
DISABLE_2FA_REMEMBER=false

# === DATABASE CONFIGURATION ===
MARIADB_ROOT_PASSWORD=generate-with-openssl-rand-base64-32
MARIADB_DATABASE=vaultwarden
MARIADB_USER=vaultwarden
MARIADB_PASSWORD=generate-with-openssl-rand-base64-32

# Database URL will be auto-constructed: mysql://user:pass@host:port/db
# Note: Uses bw_mariadb as hostname (matches service name in docker-compose)

# === REDIS CACHE CONFIGURATION ===
REDIS_PASSWORD=generate-with-openssl-rand-base64-32

# === SMTP CONFIGURATION ===
# Standardized SMTP variables (use SMTP_USERNAME, not SMTP_USER)
SMTP_HOST=smtp.mailersend.net
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=your-smtp-username-or-token
SMTP_PASSWORD=your-smtp-password-or-token
SMTP_FROM=vault@${DOMAIN_NAME}
SMTP_FROM_NAME=Vaultwarden Server

# === PUSH NOTIFICATIONS (OPTIONAL) ===
PUSH_ENABLED=true
PUSH_INSTALLATION_ID=obtain-from-bitwarden-hosting-portal
PUSH_INSTALLATION_KEY=obtain-from-bitwarden-hosting-portal
PUSH_RELAY_URI=https://push.bitwarden.com

# === BACKUP CONFIGURATION ===
BACKUP_PASSPHRASE=generate-with-openssl-rand-base64-32
BACKUP_REMOTE=your-rclone-remote-name
BACKUP_PATH=vaultwarden-backups
BACKUP_RETENTION_DAYS=30
BACKUP_EMAIL=backup@${DOMAIN_NAME}

# === CADDY REVERSE PROXY ===
ADMIN_EMAIL=admin@${DOMAIN_NAME}

# === DYNAMIC DNS (DDCLIENT) ===
DDCLIENT_PROTOCOL=cloudflare
DDCLIENT_LOGIN=your-cloudflare-email
DDCLIENT_PASSWORD=your-cloudflare-api-token
DDCLIENT_ZONE=${DOMAIN_NAME}
DDCLIENT_HOST=${APP_DOMAIN}

# === FAIL2BAN SECURITY ===
FAIL2BAN_DEST=security@${DOMAIN_NAME}

# === WATCHTOWER AUTO-UPDATES ===
WATCHTOWER_SCHEDULE=0 0 3 * * 0

# === PERFORMANCE TUNING (OCI A1 Flex Optimized) ===
# These values are optimized for 1 OCPU ARM64, 6GB RAM
DATABASE_MAX_CONNECTIONS=15
VAULTWARDEN_WORKERS=2
REDIS_MAX_CONNECTIONS=25

# === MONITORING & ALERTS ===
DISK_ALERT_THRESHOLD=85
ALERT_EMAIL=admin@${DOMAIN_NAME}
CPU_ALERT_THRESHOLD=80
MEMORY_ALERT_THRESHOLD=85
LOAD_ALERT_THRESHOLD=2.0

# Log management
LOG_RETENTION_DAYS=30
MAX_LOG_SIZE=100M

# ===========================================
# CONTAINER CONFIGURATION
# (Internal variables - do not modify)
# ===========================================

# Standardized container names for scripts
VAULTWARDEN_CONTAINER=vaultwarden
MARIADB_CONTAINER=bw_mariadb
REDIS_CONTAINER=bw_redis
CADDY_CONTAINER=bw_caddy
FAIL2BAN_CONTAINER=bw_fail2ban
BACKUP_CONTAINER=bw_backup
WATCHTOWER_CONTAINER=bw_watchtower
DDCLIENT_CONTAINER=bw_ddclient
