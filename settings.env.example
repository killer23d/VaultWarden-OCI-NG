# settings.env.example - Comprehensive non-sensitive configuration for VaultWarden
# Sensitive settings (tokens, passwords) are managed via SOPS in secrets/secrets.yaml

# --- Core Configuration ---
DOMAIN=https://vault.example.com
ADMIN_EMAIL=admin@example.com
TZ=UTC

# --- Database Configuration ---
DATABASE_URL=sqlite:///data/db.sqlite3

# --- Application Features ---
SIGNUPS_ALLOWED=false
INVITATIONS_ALLOWED=true
WEBSOCKET_ENABLED=true

# --- Performance & Resource Limits ---
VAULTWARDEN_MEMORY_LIMIT=2G
VAULTWARDEN_MEMORY_RESERVATION=768M
CADDY_MEMORY_LIMIT=512M
FAIL2BAN_MEMORY_LIMIT=256M

# --- Logging ---
LOG_LEVEL=warn
EXTENDED_LOGGING=true

# --- Backup Configuration ---
BACKUP_KEEP_DB=30
BACKUP_KEEP_FULL=8

# --- Dynamic DNS (Optional) ---
DDCLIENT_ENABLED=false
# DDCLIENT_PROTOCOL=cloudflare
# DDCLIENT_LOGIN=your-cloudflare-email@example.com
# DDCLIENT_ZONE=example.com
# DDCLIENT_HOST=vault.example.com

# --- Watchtower (Automated Updates) ---
WATCHTOWER_SCHEDULE=0 0 4 * * 1  # Every Monday at 4 AM
WATCHTOWER_CLEANUP=true