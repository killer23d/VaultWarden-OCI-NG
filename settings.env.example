# settings.env.example
# Copy to settings.env (NOT tracked) and fill in values, or store in OCI Vault and fetch at startup.

APP_DOMAIN=vault.example.com
ADMIN_EMAIL=admin@example.com

# MariaDB
MYSQL_ROOT_PASSWORD=super-secret-root
MYSQL_DATABASE=vaultwarden
MYSQL_USER=vwuser
MYSQL_PASSWORD=super-secret-db

# GPG & backup
GPG_PASSPHRASE=change_me_to_strong_passphrase
BACKUP_EMAIL_RECIPIENT=backup@example.com
SMTP_HOST=smtp.mailersend.net
SMTP_USER=smtp-user
SMTP_PASSWORD=smtp-password
SMTP_FROM=backup@example.com

# Cloudflare ddns
CF_API_TOKEN=cloudflare_api_token_with_dns_scope
DDCLIENT_DOMAIN=example.com
DDCLIENT_HOST=vault

# OCI (optional for fetching settings)
OCI_SECRET_OCID=ocid1.vaultsecret.oc1..aaaaaaa...
COMPARTMENT_OCID=ocid1.compartment.oc1..aaaaaaa...
