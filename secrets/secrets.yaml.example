# VaultWarden Encrypted Secrets Template
# This is an example/template file - the actual secrets.yaml will be encrypted
# 
# IMPORTANT: Never commit actual secret values to version control!
# Use this template to understand the structure, then create your encrypted version with:
#   cp secrets/secrets.yaml.example /tmp/my-secrets.yaml
#   # Edit /tmp/my-secrets.yaml with your actual values
#   sops -e /tmp/my-secrets.yaml > secrets/secrets.yaml
#   shred -vfz /tmp/my-secrets.yaml

# Required Secrets
admin_token: "CHANGE_ME_RANDOM_32_CHARS_FOR_ADMIN_ACCESS"
backup_passphrase: "CHANGE_ME_RANDOM_32_CHARS_FOR_BACKUP_ENCRYPTION"

# Email/SMTP Configuration
smtp_password: "your-smtp-password-here"

# Push Notifications (optional)
push_installation_key: "your-bitwarden-push-key-here-if-enabled"

# CloudFlare Integration (optional)
cloudflare_api_token: "your-cloudflare-api-token-here"

# Custom Secrets (add as needed)
# custom_api_key: "your-custom-secret-here"
# database_encryption_key: "another-custom-secret"

# Notes:
# - All values will be encrypted when stored in secrets/secrets.yaml
# - Empty strings ("") are valid for optional secrets
# - Never use placeholder values like "CHANGE_ME" in production
# - Generate strong random values for admin_token and backup_passphrase:
#   openssl rand -base64 32
# - Test decryption after encryption:
#   sops -d secrets/secrets.yaml
# - Edit encrypted secrets safely with:
#   ./tools/edit-secrets.sh
