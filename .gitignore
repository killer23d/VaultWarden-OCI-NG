# .gitignore

# === CRITICAL SECURITY FILES ===
# Main environment file containing all secrets and passwords
settings.env
# Backup encryption keys and cloud storage credentials
backup/rclone.conf

# === GENERATED CONFIGURATION FILES ===
# Generated fail2ban configuration from template
fail2ban/jail.d/jail.local
# Generated Cloudflare IP files (will be auto-created)
caddy/cloudflare_ips.caddy
caddy/cloudflare_ips.txt

# === RUNTIME DATA DIRECTORIES ===
# All persistent data should be in data/ directory
data/
# Temporary directories created during restore process
bwrestore.*
# Temporary files created by scripts
*.tmp
*.temp

# === LOG AND OUTPUT FILES ===
# Script log files
*.log
# OCI setup logs containing sensitive OCIDs
oci_vault_setup_*.log
# Backup logs that might contain sensitive information
backup_*.log

# === DEVELOPMENT AND IDE FILES ===
# Common editor and IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# === DOCKER DEVELOPMENT ===
# Development docker overrides
docker-compose.override.yml
docker-compose.dev.yml

# === SSL CERTIFICATES (if manually managed) ===
# SSL certificates should be managed by Caddy automatically
*.crt
*.key
*.pem
