# settings.env - Non-sensitive VaultWarden configuration
# This file contains all non-sensitive configuration settings.
# Sensitive settings (tokens, passwords, keys) are managed via SOPS in secrets/secrets.yaml

# Domain and basic configuration
DOMAIN=https://vault.example.com
ADMIN_EMAIL=admin@example.com

# Database configuration (non-sensitive paths and limits)
DATABASE_URL=sqlite:///data/db.sqlite3
DATABASE_MAX_CONNS=10
DATABASE_TIMEOUT=30

# Feature toggles and application behavior
SIGNUPS_ALLOWED=false
INVITATIONS_ALLOWED=true
WEBSOCKET_ENABLED=true
SHOW_PASSWORD_HINT=false
PASSWORD_ITERATIONS=100000
PASSWORD_HINTS_ALLOWED=true
DOMAIN_WHITELIST=
DISABLE_ADMIN_TOKEN=false
DISABLE_ICON_DOWNLOAD=false
RELOAD_TEMPLATES=false

# Email/SMTP configuration (non-sensitive)
SMTP_HOST=smtp.gmail.com
SMTP_FROM=noreply@example.com
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=notifications@example.com
SMTP_TIMEOUT=15
SMTP_FROM_NAME=VaultWarden
HELO_NAME=

# Push notifications (non-sensitive)
PUSH_ENABLED=false
PUSH_INSTALLATION_ID=
PUSH_RELAY_URI=https://api.bitwarden.com

# Performance and resource limits
VAULTWARDEN_MEMORY_LIMIT=2G
VAULTWARDEN_MEMORY_RESERVATION=768M
CADDY_MEMORY_LIMIT=512M
FAIL2BAN_MEMORY_LIMIT=256M
WATCHTOWER_MEMORY_LIMIT=256M
DDCLIENT_MEMORY_LIMIT=128M

# Rocket/server configuration
ROCKET_PORT=8080
ROCKET_WORKERS=10
ROCKET_TLS=off
ROCKET_LIMITS={json=10485760,forms=10485760}

# Logging and debugging
LOG_LEVEL=warn
LOG_FILE=/logs/vaultwarden.log
EXTENDED_LOGGING=true
LOG_TIMESTAMP_FORMAT=%Y-%m-%d %H:%M:%S.%3f

# System configuration
TZ=UTC
RUST_BACKTRACE=1

# Docker and container settings
RESTART_POLICY=unless-stopped
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=3
HEALTHCHECK_START_PERIOD=45s

# Network timeouts and limits
NETWORK_TIMEOUT=30
CLOUDFLARE_UPDATE_TIMEOUT=30
OCI_VAULT_TIMEOUT=15

# Backup configuration (non-sensitive)
BACKUP_KEEP_DB=30
BACKUP_KEEP_FULL=8
BACKUP_SCHEDULE_DB="0 1 * * *"
BACKUP_SCHEDULE_FULL="0 0 * * 0"

# Monitoring and health checks
MONITOR_INTERVAL=300
MONITOR_MEMORY_THRESHOLD=80
MONITOR_DISK_THRESHOLD=85
MONITOR_LOAD_THRESHOLD=2.0

# Dynamic DNS configuration (non-sensitive)
DDCLIENT_ENABLED=false
DDCLIENT_PROTOCOL=cloudflare
DDCLIENT_LOGIN=
DDCLIENT_ZONE=example.com
DDCLIENT_HOST=vault.example.com
DDCLIENT_USE=web
DDCLIENT_SSL=yes
DDCLIENT_TTL=1

# Fail2ban configuration
F2B_LOG_LEVEL=INFO
F2B_DB_PURGE_AGE=2d
F2B_MAX_RETRY=5
F2B_FINDTIME=10m
F2B_BANTIME=1h

# Watchtower configuration
WATCHTOWER_SCHEDULE=0 0 4 * * 1#1
WATCHTOWER_TIMEOUT=300
WATCHTOWER_NOTIFICATIONS=email
WATCHTOWER_CLEANUP=true

# Container names (dynamic based on project)
CONTAINER_NAME_VAULTWARDEN=${COMPOSE_PROJECT_NAME}_vaultwarden
CONTAINER_NAME_CADDY=${COMPOSE_PROJECT_NAME}_caddy
CONTAINER_NAME_FAIL2BAN=${COMPOSE_PROJECT_NAME}_fail2ban
CONTAINER_NAME_WATCHTOWER=${COMPOSE_PROJECT_NAME}_watchtower
CONTAINER_NAME_DDCLIENT=${COMPOSE_PROJECT_NAME}_ddclient

# Advanced configuration
EMERGENCY_ACCESS_ALLOWED=true
ORG_GROUPS_ENABLED=false
ORG_EVENTS_ENABLED=false
ORG_ATTACHMENT_LIMIT=
USER_ATTACHMENT_LIMIT=
TRASH_AUTO_DELETE_DAYS=

# Icon service configuration
ICON_SERVICE=internal
ICON_REDIRECT_CODE=302
ICON_CACHE_TTL=2592000
ICON_CACHE_NEGTTL=259200
ICON_DOWNLOAD_TIMEOUT=10
ICON_BLACKLIST_NON_GLOBAL_IPS=true

# Security headers and HTTPS
USE_SENDFILE=true
WEB_VAULT_ENABLED=true
WEB_VAULT_FOLDER=web-vault/

# Development and testing (production should be false/off)
DEV_MODE=false
REQUIRE_DEVICE_EMAIL=false

# Database performance tuning
DATABASE_WAL_ENABLE=true
DATABASE_VACUUM_SCHEDULE="0 2 * * 1"

# Note: Sensitive configuration values are stored in encrypted secrets:
# - ADMIN_TOKEN              -> secrets/secrets.yaml (admin_token)
# - SMTP_PASSWORD             -> secrets/secrets.yaml (smtp_password) 
# - BACKUP_PASSPHRASE         -> secrets/secrets.yaml (backup_passphrase)
# - PUSH_INSTALLATION_KEY     -> secrets/secrets.yaml (push_installation_key)
# - DDCLIENT_PASSWORD         -> secrets/secrets.yaml (cloudflare_api_token)
# - CLOUDFLARE_API_KEY        -> secrets/secrets.yaml (cloudflare_api_token)
#
# Edit encrypted secrets with: ./tools/edit-secrets.sh
# Validate configuration with: ./tools/check-health.sh
