# rclone.conf.example
# Copy this to rclone.conf and configure for your cloud provider
# Run 'rclone config' to generate your actual configuration

# Example for Backblaze B2:
# [b2-backups]
# type = b2
# account = your_account_id
# key = your_application_key
# hard_delete = false

# Example for Google Drive:
# [gdrive-backups]
# type = drive
# client_id = your_client_id
# client_secret = your_client_secret
# token = {"access_token":"your_token","token_type":"Bearer","refresh_token":"your_refresh_token","expiry":"2024-01-01T00:00:00Z"}

# Replace 'your-rclone-remote-name' in settings.env with the section name above (e.g., 'b2-backups')
